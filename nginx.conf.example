# Add this server block to your existing shared Nginx configuration.
# Replace "yoman.yourdomain.com" with your actual subdomain.

server {
    listen 80;
    server_name yoman.yourdomain.com;

    # Allow large video uploads (up to 500MB)
    client_max_body_size 500M;

    # Increase timeouts for long-running video generation
    proxy_read_timeout 300s;
    proxy_send_timeout 300s;

    # Frontend
    location / {
        proxy_pass http://yoman-frontend:3000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Backend API
    location /api/ {
        proxy_pass http://yoman-backend:8000/api/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
