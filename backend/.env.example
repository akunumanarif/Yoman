# Vast.ai
VAST_API_KEY=your_vast_api_key_here

# Paths
UPLOAD_DIR=./uploads
OUTPUT_DIR=./outputs
DB_PATH=./data/yoman.db

# GPU Preferences
GPU_MIN_VRAM=24
GPU_MAX_BID_PRICE=0.30
GPU_PREFERRED_MODELS=RTX_4090,A100,H100

# Vast.ai Docker image for GPU instances
VAST_DOCKER_IMAGE=pytorch/pytorch:2.4.0-cuda12.4-cudnn9-devel

# Worker
WORKER_POLL_INTERVAL=10
MAX_RETRIES=3
